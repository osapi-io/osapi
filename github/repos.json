{
  "org": "osapi-io",
  "repos": [
    {
      "name": "osapi",
      "description": "A Linux system management API with async job processing over NATS JetStream.",
      "topics": ["golang", "linux", "nats-jetstream", "openapi3", "osapi", "rest-api", "system-management"]
    },
    {
      "name": "osapi-sdk",
      "description": "Go SDK for OSAPI — client library and orchestration primitives.",
      "topics": ["dag", "golang", "nats-jetstream", "openapi3", "orchestration", "osapi", "sdk"]
    },
    {
      "name": "nats-client",
      "description": "A Go package for connecting to and interacting with a NATS server.",
      "topics": ["golang", "messaging", "nats-client", "nats-jetstream", "osapi"]
    },
    {
      "name": "nats-server",
      "description": "A Go package for running an embedded NATS server.",
      "topics": ["golang", "messaging", "nats-jetstream", "nats-server", "osapi"]
    },
    {
      "name": "osapi-justfiles",
      "description": "Shared justfiles for osapi-io projects.",
      "topics": ["justfile", "osapi"]
    },
    {
      "name": "osapi-orchestrator",
      "description": "A Go package for orchestrating operations across OSAPI-managed hosts.",
      "topics": ["configuration-management", "dag", "golang", "orchestration", "osapi"]
    }
  ],
  "security": {
    "vulnerability_alerts": true,
    "dependabot_security_updates": true,
    "secret_scanning": true,
    "secret_scanning_push_protection": true
  },
  "settings": {
    "has_issues": true,
    "has_wiki": false,
    "has_projects": false,
    "delete_branch_on_merge": true,
    "allow_merge_commit": false,
    "allow_squash_merge": true,
    "allow_rebase_merge": true,
    "allow_auto_merge": true,
    "web_commit_signoff_required": false
  },
  "branch_protection": {
    "branch": "main",
    "enforce_admins": true,
    "required_status_checks": { "strict": true },
    "required_pull_request_reviews": { "required_approving_review_count": 0 },
    "required_conversation_resolution": true,
    "allow_force_pushes": false,
    "allow_deletions": false,
    "block_creations": true,
    "restrictions": { "users": ["retr0h"], "teams": [], "apps": [] }
  }
}
